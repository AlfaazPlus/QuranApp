{
    "1": {
        "title": "അല്ലാഹുവിൽ പങ്കുചേർക്കൽ (ശിർക്ക്)"
    },
    "2": "അന്യായമായി ഒരു മനുഷ്യനെ കൊല്ലുക",
    "3": "സിഹ്ർ (അഭിചാരം) ചെയ്യുക",
    "4": "നമസ്കാരം ഉപേക്ഷിക്കുക",
    "5": "സകാത്ത് നൽകാതിരിക്കുക",
    "6": "ശരിയായ കാരണമില്ലാതെ റമദാനിലെ വ്രതം ഉപേക്ഷിക്കുക",
    "7": "കഴിവുണ്ടായിട്ടും ഹജ്ജ് ചെയ്യാതിരിക്കുക",
    "8": "മാതാപിതാക്കളോട് അനാദരവ് കാണിക്കുക",
    "9": "കുടുംബബന്ധം വിച്ഛേദിക്കുക",
    "10": "വ്യഭിചാരം",
    "11": "സ്വവർഗ്ഗരതി",
    "12": "പലിശ (രിബ)",
    "13": "അനാഥയുടെ സ്വത്ത് അന്യായമായി ഭക്ഷിക്കുക",
    "14": "അല്ലാഹുവിൻ്റെയും റസൂലിൻ്റെയും പേരിൽ കളവ് പറയുക",
    "15": "യുദ്ധക്കളത്തിൽ നിന്ന് ഓടിപ്പോകുക",
    "16": "ജനങ്ങളെ വഴിപിഴപ്പിക്കുന്ന ഭരണാധികാരി, സ്വേച്ഛാധിപതി, അക്രമി",
    "17": "അഹങ്കാരം, ഗർവ്വ്, സ്വയം പുകഴ്ത്തൽ",
    "18": "കള്ളസാക്ഷി പറയുക",
    "19": "മദ്യപാനം, ചൂതാട്ടം",
    "20": "സദ്‌വൃത്തരായ സ്ത്രീകളെ അപവാദം പറയുക",
    "21": "യുദ്ധമുതൽ, പൊതുസ്വത്ത്, സകാത്ത് എന്നിവ അപഹരിക്കുക",
    "22": "മോഷണം",
    "23": "വഴിപിടിച്ചുപറി",
    "24": "കള്ളസത്യം ചെയ്യുക",
    "25": "അന്യായമായി മറ്റുള്ളവരുടെ സ്വത്ത് കൈക്കലാക്കുക",
    "26": "അവിഹിത സമ്പാദ്യം",
    "27": "ഹറാം ഭക്ഷിക്കൽ, കൈക്കൂലി",
    "28": "ആത്മഹത്യ",
    "29": "കളവ് പറയുക",
    "30": "നീതിയില്ലാത്ത ന്യായാധിപൻ",
    "31": "വേശ്യാവൃത്തിക്ക് ഒത്താശ ചെയ്യുന്നവൻ (ദയൂസ്)",
    "32": "മൂത്രത്തിൽ നിന്ന് ശുദ്ധിയാകാതിരിക്കുക",
    "33": "സൽക്കർമ്മങ്ങളിൽ ലോകമാന്യം കാണിക്കൽ (റിയ)",
    "34": "ദുനിയാവിനുവേണ്ടി മതവിദ്യ അഭ്യസിക്കുകയോ അത് മറച്ചുവെക്കുകയോ ചെയ്യുക",
    "35": "വിശ്വാസവഞ്ചന",
    "36": "ദാനം ചെയ്തിട്ട് അത് എടുത്തുപറഞ്ഞ് വിഷമിപ്പിക്കുക",
    "37": "വിധിയെ (ഖദ്ർ) നിഷേധിക്കുക",
    "38": "മറ്റുള്ളവരുടെ സ്വകാര്യ സംഭാഷണങ്ങൾ ഒളിഞ്ഞു കേൾക്കുക",
    "39": "കരാറുകളോ വാഗ്ദാനങ്ങളോ ലംഘിക്കുക",
    "40": "ജ്യോത്സ്യന്മാരെയും മന്ത്രവാദികളെയും വിശ്വസിക്കുക",
    "41": "ഭർത്താവിനോടുള്ള ഭാര്യയുടെ അനുസരണക്കേട്",
    "42": "വിഗ്രഹങ്ങളും രൂപങ്ങളും നിർമ്മിക്കുക",
    "43": "വിപത്തുകൾ വരുമ്പോൾ അമിതമായി വിലപിക്കുക, വസ്ത്രം കീറുക, സ്വയം അടിക്കുക",
    "44": "മറ്റുള്ളവരോട് അന്യായമായി പെരുമാറുക",
    "45": "മറ്റുള്ളവരോടുള്ള അതിക്രമവും അഹങ്കാരവും",
    "46": "മുസ്ലീങ്ങളെ ഉപദ്രവിക്കുകയോ ശകാരിക്കുകയോ ചെയ്യുക, അല്ലാഹുവിൻ്റെ ദാസന്മാരെ ദ്രോഹിക്കുക",
    "47": "അഹങ്കാരത്തോടെ വസ്ത്രം വലിച്ചിഴച്ച് നടക്കുക",
    "48": "അല്ലാഹു അല്ലാത്തവരുടെ നാമത്തിൽ അറുക്കുക",
    "49": "തർക്കിക്കുക, മറ്റുള്ളവരുടെ വാക്കുകളിൽ കുറ്റം പിടിക്കുക, ശണ്ഠ കൂടുക",
    "50": "അളവിലും തൂക്കത്തിലും കുറവ് വരുത്തുക",
    "51": "അല്ലാഹുവിൻ്റെ ശിക്ഷയെക്കുറിച്ച് നിർഭയനായിരിക്കുക",
    "52": {
        "title": "അല്ലാഹുവിൻ്റെ കാരുണ്യത്തിൽ നിന്ന് നിരാശപ്പെടുക",
        "description": "പശ്ചാത്താപത്തിൻ്റെയും പാപമോചനത്തിൻ്റെയും പശ്ചാത്തലത്തിലും ഇത് പരാമർശിക്കപ്പെടുന്നു."
    },
    "53": "മരണപത്രത്തിലൂടെ അവകാശികളുടെ അവകാശം തടയുക",
    "54": "വഞ്ചനയും കുതന്ത്രങ്ങളും",
    "55": "സാഹചര്യങ്ങൾക്കനുസരിച്ച് ചില പാപങ്ങൾ വൻപാപങ്ങളായി കണക്കാക്കപ്പെടാതിരിക്കാം",
    "56": "അല്ലാഹു നിരോധിച്ച കാര്യങ്ങൾ അവഗണിക്കുകയോ അത് അനുവദനീയമാണെന്ന് കരുതുകയോ ചെയ്യുന്നത് വൻപാപമാണ്",
    "57": "ചെറുദോഷങ്ങളിൽ ഉറച്ചുനിൽക്കുന്നത് അതിനെ വൻദോഷമാക്കും",
    "58": "പാപങ്ങൾ വ്യക്തിപരമോ (അല്ലാഹുവുമായി ബന്ധപ്പെട്ടത്) മറ്റുള്ളവരുടെ അവകാശങ്ങളുമായി ബന്ധപ്പെട്ടതോ ആകാം",
    "59": "പരസ്യമായി പാപം ചെയ്യുന്നത് അതീവ ഗുരുതരമായ കുറ്റമാണ്"
}
