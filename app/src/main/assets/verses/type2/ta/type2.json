{
  "1": "பேச்சில் கடுமை காட்டாதீர்கள்",
  "2": "கோபத்தை கட்டுப்படுத்துங்கள்",
  "3": "மற்றவர்களுக்கு நன்மை செய்யுங்கள்",
  "4": "அகந்தை கொள்ளாதீர்கள்",
  "5": "மற்றவர்களின் தவறுகளை மன்னியுங்கள்",
  "6": "மக்களிடம் மென்மையாகப் பேசுங்கள்",
  "7": "ஒருவரை ஒருவர் கேலி செய்யாதீர்கள்",
  "8": "பெற்றோரை நோக்கி 'சீ' என்று கூடச் சொல்லாதீர்கள் (அவமதிக்காதீர்கள்)",
  "9": "யாரையும் குருட்டுத்தனமாகப் பின்பற்றாதீர்கள்",
  "10": "கடனாளி சிரமத்தில் இருந்தால் கடனைத் திருப்பிக் கொடுக்க கூடுதல் அவகாசம் கொடுங்கள்",
  "11": "லஞ்சம் கொடுக்கவோ வாங்கவோ செய்யாதீர்கள்",
  "12": "வாக்குறுதிகளை மீறாதீர்கள்",
  "13": "நீதிக்காக உறுதியாக நில்லுங்கள்",
  "14": "பெண்களுக்கும் சொத்தில் உரிமை உண்டு",
  "15": "அநாதைகளைப் பாதுகாக்கவும்",
  "16": "ஒருவருக்கொருவர் சொத்துக்களை அநியாயமாக அபகரிக்காதீர்கள்",
  "17": "மக்களிடையே சமரசம் செய்ய முயற்சி செய்யுங்கள்",
  "18": "வீண் சந்தேகங்களைத் தவிர்க்கவும்",
  "19": "உளவு பார்க்காதீர்கள் மற்றும் புறம் பேசாதீர்கள்",
  "20": "செல்வத்தை தர்மத்திற்காக செலவிடுங்கள்",
  "21": "தேவையுள்ளவர்களைத் தேடிக் கண்டுபிடித்து உதவுங்கள்",
  "22": "தேவையுள்ளவர்களிடம் கனிவாகப் பேசுங்கள்",
  "23": "விருந்தினர்களைக் கௌரவியுங்கள்",
  "24": "பெற்றோருக்குக் கடமையுள்ளவர்களாக இருங்கள்",
  "25": "நீங்கள் எதைச் செய்கிறீர்களோ அதை மற்றவர்களுக்கு அறிவுறுத்துங்கள்",
  "26": "ஊழலில் இருந்து விலகி இருங்கள்",
  "27": "உங்களுடன் போரிடுபவர்களுடன் மட்டும் போரிடுங்கள்",
  "28": "தொடர்ந்து முயற்சி செய்யுங்கள்",
  "29": "மார்க்கத்தில் வற்புறுத்தல் இல்லை",
  "30": "ஆட்சியாளர்களை அவர்களின் தகுதியின் அடிப்படையில் தேர்ந்தெடுங்கள்",
  "31": "பிரிந்து விடாதீர்கள்",
  "32": "கஞ்சத்தனம் காட்டாதீர்கள்",
  "33": "பொறாமை கொள்ளாதீர்கள்",
  "34": "மோசடி செய்பவர்களுக்கு ஆதரவாக இருக்காதீர்கள்",
  "35": "பாவம் மற்றும் அத்துமீறலில் இருந்து விலகி இருங்கள்",
  "36": "நீதியாக இருங்கள்",
  "37": "போதைப்பொருள் மற்றும் மதுவைத் தவிர்க்கவும்",
  "38": "சூதாடாதீர்கள்",
  "39": "மற்றவர்களின் தெய்வங்களை இகழாதீர்கள்",
  "40": "உண்ணுங்கள் மற்றும் பருகுங்கள், ஆனால் வீண் விரயம் செய்யாதீர்கள்",
  "41": "தஞ்சம் தேடுபவர்களைப் பாதுகாக்கவும் மற்றும் உதவவும்",
  "42": "அல்லாஹ்வின் பக்கம் அழைப்பது ஞானத்துடனும் அழகிய அறிவுரையுடனும் இருக்க வேண்டும்",
  "43": "உங்களுக்கு அறிவு இல்லாத ஒன்றைப் பின்பற்றாதீர்கள்",
  "44": "வீணான விஷயங்களிலிருந்து விலகி இருங்கள்",
  "45": "அனுமதி பெறாமல் மற்றவர்களின் வீடுகளுக்குள் நுழையாதீர்கள்",
  "46": "பூமியில் பணிவுடன் நடங்கள்",
  "47": "மக்களிடையே நீதியுடன் தீர்ப்பளியுங்கள்",
  "48": "இந்த உலகத்தில் உங்களுக்குரிய பங்கினை மறந்து விடாதீர்கள்",
  "49": "நன்மையை ஏவி, தீமையைத் தடையுங்கள்",
  "50": "பூமியில் அகந்தையுடன் நடக்காதீர்கள்",
  "51": "பெண்கள் தங்கள் அலங்காரங்களை வெளிப்படுத்த வேண்டாம்",
  "52": "அல்லாஹ்வின் கருணையில் நம்பிக்கையிழக்காதீர்கள்",
  "53": "காரியங்களை ஆலோசனையின் மூலம் முடிவு செய்யுங்கள்",
  "54": "அனைத்து மதத்தவர்களிடமும் நீதியுடன் நடந்து கொள்ளுங்கள்"
}
